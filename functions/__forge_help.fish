function __forge_help
    echo 'Forge fish plugin help'
    echo '  : <prompt>                 send prompt with active agent'
    echo '  :sage <prompt>            send prompt with explicit agent'
    echo '  :agent                    pick active agent'
    echo '  :conversation             pick or switch conversation'
    echo '  :doctor                   run fish-specific diagnostics'
    echo '  :help                     show this help'
    echo '  @ + TAB                   insert @[path] from file picker'
    echo '  Set FORGE_FISH_PROMPT=1   enable right prompt integration'
end
